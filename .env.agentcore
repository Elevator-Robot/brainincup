# AgentCore Environment Variables
# These are used by the Amplify/CDK backend to configure the AgentCore runtime
# All values are auto-detected or have sensible defaults

# Container URI is auto-detected from ECR during deployment
# Format: {account-id}.dkr.ecr.{region}.amazonaws.com/brain-agent:latest
# AGENTCORE_CONTAINER_URI=

# Runtime name is auto-generated from stack name (unique per environment)
# AGENTCORE_RUNTIME_NAME=

# Network mode: PUBLIC or VPC
AGENTCORE_NETWORK_MODE=PUBLIC

# Tracing configuration (optional)
AGENTCORE_TRACE_ENABLED=false
AGENTCORE_TRACE_SAMPLE_RATE=0.0
