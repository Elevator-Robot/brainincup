{
  "name": "brain-in-cup",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --debug",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest --run",
    "delete:sandbox": "bash ./scripts/delete-sandbox.sh",
    "deploy:sandbox": "bash ./scripts/deploy-sandbox.sh",
    "deploy:runtime": "bash ./scripts/update-agent-image.sh",
    "deploy:all": "bash ./scripts/update-agent-image.sh && bash ./scripts/deploy-sandbox.sh",
    "logs": "bash ./scripts/fetch-logs.sh"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^6.5.5",
    "@fontsource/cinzel": "^5.2.8",
    "@fontsource/medievalsharp": "^5.2.8",
    "@react-three/fiber": "^8.17.14",
    "@react-three/rapier": "^1.5.0",
    "aws-amplify": "^6.11.0",
    "aws-sdk": "^2.1692.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.17",
    "three": "^0.164.1"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.5.0",
    "@aws-amplify/backend-cli": "^1.2.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.15.21",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@types/three": "^0.183.1",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^4.1.4",
    "autoprefixer": "^10.4.20",
    "aws-cdk": "^2.138.0",
    "aws-cdk-lib": "^2.138.0",
    "constructs": "^10.3.0",
    "esbuild": "^0.20.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "tsx": "^4.7.2",
    "typescript": "^5.8.2",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^1.0.3",
    "vitest": "^4.1.4",
    "workbox-window": "^7.3.0"
  }
}
